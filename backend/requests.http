### ============================================================
### TRUCK & ROLL - API Test Suite
### Extension: REST Client (VS Code)
### Ejecutar seed primero: python backend/seed.py
### ============================================================

@base = http://localhost:8000

### ============================================================
### HEALTH CHECK
### ============================================================

### Estado de la API
GET {{base}}/

### ============================================================
### MENU - Ver productos
### ============================================================

### Ver menu completo
GET {{base}}/menu/

### ============================================================
### AUTH - Registro y Login
### ============================================================

### Registrar cliente nuevo
POST {{base}}/auth/register
Content-Type: application/json

{
  "nombre": "Test User",
  "email": "test@email.com",
  "telefono": "099777888",
  "password": "test1234"
}

### Login con cliente del seed (juan)
# @name loginJuan
POST {{base}}/auth/login
Content-Type: application/json

{
  "email": "juan@email.com",
  "password": "1234"
}

### Login con cliente del seed (maria)
# @name loginMaria
POST {{base}}/auth/login
Content-Type: application/json

{
  "email": "maria@email.com",
  "password": "1234"
}

### ============================================================
### PEDIDOS - Crear, consultar y pagar
### ============================================================

### Extraer token del login de Juan
@tokenJuan = {{loginJuan.response.body.$.access_token}}

### Extraer token del login de Maria
@tokenMaria = {{loginMaria.response.body.$.access_token}}

### Crear pedido (Juan)
# @name crearPedido
POST {{base}}/pedidos/
Content-Type: application/json
X-Cliente-Id: {{tokenJuan}}

{
  "items": [
    { "producto_id": "REEMPLAZAR_CON_ID_PRODUCTO", "cantidad": 2 },
    { "producto_id": "REEMPLAZAR_CON_ID_PRODUCTO", "cantidad": 1 }
  ]
}

### Nota: Para obtener IDs de productos, ejecutar GET /menu/ primero
### y reemplazar los valores arriba con los IDs reales.

### Consultar pedido (Juan)
GET {{base}}/pedidos/{{pedidoId}}
X-Cliente-Id: {{tokenJuan}}

### Pagar pedido con EFECTIVO
POST {{base}}/pedidos/{{pedidoId}}/pagar
Content-Type: application/json
X-Cliente-Id: {{tokenJuan}}

{
  "metodo_pago": "EFECTIVO"
}

### Pagar pedido con TARJETA
POST {{base}}/pedidos/{{pedidoId}}/pagar
Content-Type: application/json
X-Cliente-Id: {{tokenJuan}}

{
  "metodo_pago": "TARJETA",
  "datos_externos": { "ultimos_4": "1234" }
}

### Pagar pedido con MERCADO_PAGO
POST {{base}}/pedidos/{{pedidoId}}/pagar
Content-Type: application/json
X-Cliente-Id: {{tokenJuan}}

{
  "metodo_pago": "MERCADO_PAGO",
  "datos_externos": { "preference_id": "pref_abc123" }
}

### ============================================================
### COCINA - Gestion de estados
### ============================================================

### Ver pedidos activos (no requiere auth)
GET {{base}}/cocina/pedidos

### Avanzar pedido a EN_PREPARACION
PATCH {{base}}/cocina/pedidos/{{pedidoId}}/estado
Content-Type: application/json

{
  "estado": "EN_PREPARACION"
}

### Avanzar pedido a LISTO (dispara notificacion al cliente)
PATCH {{base}}/cocina/pedidos/{{pedidoId}}/estado
Content-Type: application/json

{
  "estado": "LISTO"
}

### Avanzar pedido a ENTREGADO
PATCH {{base}}/cocina/pedidos/{{pedidoId}}/estado
Content-Type: application/json

{
  "estado": "ENTREGADO"
}

### ============================================================
### NOTIFICACIONES
### ============================================================

### Ver mis notificaciones (Juan)
GET {{base}}/notificaciones/
X-Cliente-Id: {{tokenJuan}}

### Ver mis notificaciones (Maria)
GET {{base}}/notificaciones/
X-Cliente-Id: {{tokenMaria}}

### Marcar notificacion como leida
PATCH {{base}}/notificaciones/REEMPLAZAR_CON_NOTIF_ID/leida
X-Cliente-Id: {{tokenJuan}}

### ============================================================
### MENU - Gestion de productos (admin)
### ============================================================

### Agregar producto nuevo
POST {{base}}/menu/
Content-Type: application/json

{
  "nombre": "Producto Test",
  "descripcion": "Descripcion del producto de prueba",
  "precio": 350.0,
  "disponibilidad": 10,
  "categoria": "Test"
}

### Actualizar producto
PUT {{base}}/menu/REEMPLAZAR_CON_ID_PRODUCTO
Content-Type: application/json

{
  "precio": 400.0,
  "disponibilidad": 5
}

### Cambiar stock de producto
PATCH {{base}}/menu/REEMPLAZAR_CON_ID_PRODUCTO/stock?cantidad=20

### ============================================================
### FLUJO COMPLETO DE PRUEBA
### ============================================================

### Paso 1: Login
# @name paso1Login
POST {{base}}/auth/login
Content-Type: application/json

{
  "email": "carlos@email.com",
  "password": "1234"
}

### Paso 2: Ver menu
GET {{base}}/menu/

### Paso 3: Crear pedido (usar IDs del menu)
# @name paso3CrearPedido
POST {{base}}/pedidos/
Content-Type: application/json
X-Cliente-Id: {{paso1Login.response.body.$.access_token}}

{
  "items": [
    { "producto_id": "REEMPLAZAR_CON_ID_PRODUCTO", "cantidad": 1 }
  ]
}

### Paso 4: Pagar pedido
POST {{base}}/pedidos/REEMPLAZAR_CON_PEDIDO_ID/pagar
Content-Type: application/json
X-Cliente-Id: {{paso1Login.response.body.$.access_token}}

{
  "metodo_pago": "EFECTIVO"
}

### Paso 5: Cocina - Ver pedidos
GET {{base}}/cocina/pedidos

### Paso 6: Cocina - Avanzar estados
PATCH {{base}}/cocina/pedidos/REEMPLAZAR_CON_PEDIDO_ID/estado
Content-Type: application/json

{
  "estado": "EN_PREPARACION"
}

### Paso 7: Cocina - Marcar LISTO
PATCH {{base}}/cocina/pedidos/REEMPLAZAR_CON_PEDIDO_ID/estado
Content-Type: application/json

{
  "estado": "LISTO"
}

### Paso 8: Cliente - Ver notificaciones
GET {{base}}/notificaciones/
X-Cliente-Id: {{paso1Login.response.body.$.access_token}}
